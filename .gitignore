# LFE Template — Git Ignore

# === OS ===
.DS_Store
Thumbs.db
Desktop.ini

# === IDE / Editor ===
.vscode/
.idea/
*.swp
*.swo

# === Dependencies ===
node_modules/

# === Environment & Secrets ===
.env
.env.local
.env.production
.env.*.local

# === Build output ===
dist/
build/
out/
.vite/

# === Logs ===
*.log
npm-debug.log*

# === Python ===
__pycache__/
.venv/

# === Local AI history ===
.gemini/

# === LFE Runtime ===
# `.plans/` itself is committed (with .gitkeep) so the coordination directory
# exists on clone, but the per-mission coordination files inside it are
# transient — they exist only during an active mission and are cleared by the
# Archivist at mission close. They are never committed.
.plans/*
!.plans/.gitkeep
